<UserControl
    x:Class="SharkSpirit.Modules.SceneInspector.Views.TransformComponentView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>

        <!--  Position  -->
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>

            <TextBlock Margin="0,10" Text="Position : " />

            <StackPanel Grid.Row="1" Orientation="Horizontal">
                <TextBlock Text="X : " />
                <xctk:DoubleUpDown
                    Width="80"
                    Increment="0.1"
                    Value="{Binding PositionX, Mode=TwoWay}" />
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal">
                <TextBlock Text="Y : " />
                <xctk:DoubleUpDown
                    Width="80"
                    Increment="0.1"
                    Value="{Binding PositionY, Mode=TwoWay}" />
            </StackPanel>

            <StackPanel Grid.Row="3" Orientation="Horizontal">
                <TextBlock Text="Z : " />
                <xctk:DoubleUpDown
                    Width="80"
                    Increment="0.1"
                    Value="{Binding PositionZ, Mode=TwoWay}" />
            </StackPanel>
        </Grid>

        <!--  Rotation  -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>

            <TextBlock Margin="0,10" Text="Rotation : " />


            <StackPanel Grid.Row="1" Orientation="Horizontal">
                <TextBlock Text="X : " />
                <xctk:DoubleUpDown
                    Width="80"
                    Increment="0.1"
                    Value="{Binding RotationX, Mode=TwoWay}" />
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal">
                <TextBlock Text="Y : " />
                <xctk:DoubleUpDown
                    Width="80"
                    Increment="0.1"
                    Value="{Binding RotationY, Mode=TwoWay}" />
            </StackPanel>

            <StackPanel Grid.Row="3" Orientation="Horizontal">
                <TextBlock Text="Z : " />
                <xctk:DoubleUpDown
                    Width="80"
                    Increment="0.1"
                    Value="{Binding RotationZ, Mode=TwoWay}" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
